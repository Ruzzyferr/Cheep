# ============================================
# ROOT LEVEL .gitignore
# Tüm projeler için ortak ignore kuralları
# ============================================

# ============================================
# Node.js / npm / pnpm / yarn
# ============================================
node_modules/
.pnpm/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ============================================
# IDE / Editor
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ============================================
# Build / Dist / Output
# ============================================
dist/
build/
out/
.next/
.nuxt/
.cache/
.turbo/

# ============================================
# Logs
# ============================================
*.log
logs/
*.log.*

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# OS Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ============================================
# Project Specific
# ============================================
# Scraper output files
Cheep-Scraper/data/*.json
Cheep-Scraper/migros/*.json
Cheep-Scraper/carrefour/*.json
Cheep-Scraper/countries/**/output/*.json
scalable-matcher.log

# Mobile build files
Cheep-Mobile/.expo/
Cheep-Mobile/web-build/
Cheep-Mobile/ios/
Cheep-Mobile/android/

# Backend build files
cheep-backend-express/dist/
cheep-backend-express/build/








