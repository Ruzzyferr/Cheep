# OpenAI/OpenRouter API Configuration
# OpenRouter kullanmak için (önerilen):
OPENROUTER_API_KEY=your-openrouter-key-here
USE_OPENROUTER=true

# VEYA OpenAI kullanmak için:
# OPENAI_API_KEY=sk-your-openai-key-here

# LLM Model Selection
# OpenRouter için: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, vb.
# OpenAI için: gpt-4o-mini, gpt-4o, vb.
LLM_MODEL=openai/gpt-4o-mini

# Optional Settings
AUTO_CREATE_SUBCATEGORIES=false
